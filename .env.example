# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----------------------------------------------------------------------------
# Flutterwave (v4 — Pay With Bank Transfer). Server-only; never expose client-side.
# Never commit real values here — fill these in .env.local (gitignored) or in the
# deployment environment. Defaults in lib/flutterwave/config.ts lean to production
# (GHS); override for sandbox testing as noted below.
# ----------------------------------------------------------------------------
# OAuth client credentials from the Flutterwave dashboard.
# Sandbox values for local testing; LIVE values (from the client's approved
# Ghanaian account) for production.
FLUTTERWAVE_CLIENT_ID=your-flutterwave-client-id
FLUTTERWAVE_CLIENT_SECRET=your-flutterwave-client-secret

# Secret hash you set in the dashboard; used to verify the `flutterwave-signature`
# header on incoming webhooks. Must match the dashboard value exactly. Generate a
# fresh random value for production (do not reuse the sandbox hash).
FLUTTERWAVE_SECRET_HASH=your-flutterwave-secret-hash

# API base URL.
#   Sandbox (testing): https://developersandbox-api.flutterwave.com
#   Production: confirm the v4 production base from the live dashboard before go-live.
FLUTTERWAVE_API_BASE_URL=https://developersandbox-api.flutterwave.com

# OAuth token endpoint (rarely needs changing).
# FLUTTERWAVE_TOKEN_URL=https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token

# Currency for charges. GHS for the live Ghanaian account.
# Override to NGN for sandbox testing against the Nigerian developer account.
FLUTTERWAVE_CURRENCY=GHS

# How long a dynamic virtual account stays open, in minutes (min 60).
FLUTTERWAVE_VA_EXPIRY_MINUTES=60
