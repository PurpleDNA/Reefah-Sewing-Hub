# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----------------------------------------------------------------------------
# Flutterwave (v4 — Pay With Bank Transfer). Server-only; never expose client-side.
# ----------------------------------------------------------------------------
# OAuth client credentials from the Flutterwave dashboard.
FLUTTERWAVE_CLIENT_ID=d528da8a-086e-4959-bb0c-52ca58754924
FLUTTERWAVE_CLIENT_SECRET=HO6f03cDmAhVutzsqwfvnvW7fWuc8lxp

# Secret hash you set in the dashboard; used to verify the `flutterwave-signature`
# header on incoming webhooks. Must match the dashboard value exactly.
FLUTTERWAVE_SECRET_HASH=5a341886c07e2f6d4c4e9d90798bc28bdfd6cd480d525bd514537ab95b76b176

# API base URL. Defaults to the sandbox; set the production base at go-live.
FLUTTERWAVE_API_BASE_URL=https://developersandbox-api.flutterwave.com

# OAuth token endpoint (rarely needs changing).
# FLUTTERWAVE_TOKEN_URL=https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token

# Currency for charges. NGN for the Nigerian sandbox account used in testing;
# switch to GHS for the live Ghanaian account.
FLUTTERWAVE_CURRENCY=NGN

# How long a dynamic virtual account stays open, in minutes.
FLUTTERWAVE_VA_EXPIRY_MINUTES=60
